{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "useDefineForClassFields": true,
    "types": ["vitest/globals", "@testing-library/jest-dom", "node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "react": ["node_modules/@types/react"],
      "react/jsx-runtime": ["node_modules/@types/react/jsx-runtime"],
      "react/jsx-dev-runtime": ["node_modules/@types/react/jsx-dev-runtime"],
      "react/*": ["node_modules/@types/react/*"],
      "react-dom": ["node_modules/@types/react-dom"],
      "react-dom/*": ["node_modules/@types/react-dom/*"],
      "react-router-dom": ["node_modules/react-router-dom"],
      "@tanstack/react-query": ["node_modules/@tanstack/react-query"],
      "@testing-library/*": ["node_modules/@testing-library/*"],
      "vitest": ["node_modules/vitest"],
      "vitest/*": ["node_modules/vitest/*"],
      "zod": ["node_modules/zod"]
    }
  },
  "include": ["src", "vite.config.ts", "vitest.setup.ts", "../tests/frontend/**/*"],
  "ts-node": {
    "compilerOptions": {
      "module": "ESNext"
    }
  }
}
